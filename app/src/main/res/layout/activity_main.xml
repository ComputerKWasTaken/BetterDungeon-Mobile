<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bd_background">

    <!-- Main WebView for play.aidungeon.com -->
    <WebView
        android:id="@+id/webview_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- FAB to toggle popup panel -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_popup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_marginBottom="32dp"
        android:contentDescription="BetterDungeon Settings"
        app:tint="@android:color/white"
        app:backgroundTint="@color/bd_accent"
        app:srcCompat="@drawable/ic_bd_settings"
        app:fabSize="normal"
        app:elevation="6dp" />

    <!-- Full Screen Popup UI -->
    <FrameLayout
        android:id="@+id/popup_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bd_surface"
        android:visibility="gone"
        android:translationY="0dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="16dp">

        <!-- Popup WebView -->
        <WebView
            android:id="@+id/webview_popup"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

</FrameLayout>
